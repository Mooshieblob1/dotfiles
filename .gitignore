# wallust runtime-generated theme outputs. These are re-rendered on every
# theme/wallpaper change; their source templates live in
# wallust/.config/wallust/templates, which IS tracked.
hypr/.config/hypr/colors.conf
waybar/.config/waybar/colors.css
waybar/.config/waybar/calendar-colors.jsonc
wofi/.config/wofi/colors.css
eww/.config/eww/colors.scss
mako/.config/mako/config

# machine-specific fish state
fish/.config/fish/fish_variables

# editor sessions, backups, nix build artifacts
.claude/
*.bak
result
result-*
